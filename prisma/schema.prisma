generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Use direct Postgres for migrations; use pooler URL in DATABASE_URL on Vercel (see .env.example).
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
  INSPECTOR
  INSPECTION_MANAGER
}

enum LotStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  LIVE
  RESERVED
  SOLD_OUT
  DISPATCHED
  CANCELLED
}

enum LotItemCondition {
  BRAND_NEW
  REFURB_A_PLUS
  REFURB_A
  REFURB_B
  REFURB_C
  REFURB_D
}

enum InspectorType {
  INHOUSE
  OUTSOURCED
}

enum VerificationStatus {
  PENDING_ASSIGNMENT
  ASSIGNED
  SLOT_PROPOSED
  SCHEDULED
  INSPECTION_COMPLETE
  APPROVED
  REJECTED
  CANCELLED
}

enum ListingType {
  PRODUCT_LISTING
  LOT
  ASAS
}

enum BidStatus {
  PENDING
  APPROVED
  REJECTED
  COUNTER_OFFERED
  EXPIRED
  PAID
  CANCELLED
}

enum OrderStatus {
  PAYMENT_PENDING
  ORDER_PLACED
  ORDER_CONFIRMED
  PACKED
  DISPATCHED
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_CONFIRMED
  PAYOUT_PENDING
  PAYOUT_RELEASED
  RETURN_REQUESTED
  REFUNDED
  CANCELLED
  TOKEN_PAID
  STOCK_RESERVED
  BALANCE_OVERDUE
  BALANCE_PAID
  TOKEN_FORFEITED
}

enum ReviewType {
  CUSTOMER_EXPERIENCE
  VENDOR_CUSTOMER
}

enum PayoutStatus {
  PENDING
  PROCESSING
  RELEASED
  FAILED
}

enum InvoiceType {
  PROFORMA
  TAX
  CREDIT_NOTE
}

enum VendorStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

enum ProductCondition {
  BRAND_NEW
  REFURB_A_PLUS
  REFURB_A
  REFURB_B
  REFURB_C
  REFURB_D
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String           @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  phone            String?          @unique
  passwordHash     String
  role             Role             @default(CUSTOMER)
  isVerified       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  vendorProfile    VendorProfile?
  customerProfile  CustomerProfile?
  addresses        Address[]
  notifications    Notification[]
  supportTickets   SupportTicket[]
  reviewsWritten   Review[]         @relation("ReviewsWritten")
  inspector        Inspector?
}

model VendorProfile {
  id                       String           @id @default(cuid())
  userId                   String           @unique
  user                     User             @relation(fields: [userId], references: [id])
  companyName              String
  gstin                    String           @unique
  pan                      String
  bankAccount              String
  ifscCode                 String
  accountName              String
  commissionRate           Float            @default(8.0)
  status                   VendorStatus     @default(PENDING_APPROVAL)
  approvedAt               DateTime?
  avgRating                Float            @default(0)
  reviewCount              Int              @default(0)
  acceptedPaymentMethods   String[]         @default(["UPI", "NET_BANKING", "CARD", "RAZORPAY_LINK", "TOKEN_PAYMENT"])
  requiresFullAdvance      Boolean          @default(false)
  minOrderForRTGS          Float?
  minTokenPercentage       Int              @default(2)
  acceptsTokenPayment      Boolean          @default(true)
  listings                 ProductListing[]
  payouts                  Payout[]
  lots                     LotListing[]
  asasListings             AsAsListing[]
  verificationTasks        VerificationTask[]
}

model CustomerProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  companyName String?
  gstin       String?
  gstVerified Boolean @default(false)
  avgRating   Float   @default(0)
  reviewCount Int     @default(0)
  bids        Bid[]
  orders      Order[]
  cart        Cart?
  lotPurchases   LotPurchase[]
  asasPurchases  AsAsPurchase[]
  lotBids        LotBid[]
  asAsBids       AsAsBid[]
}

model Cart {
  id          String          @id @default(cuid())
  customerId  String          @unique
  customer    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items       Json            @default("[]")
  updatedAt   DateTime        @updatedAt
}

model PendingRegistration {
  id               String   @id @default(cuid())
  email            String   @unique
  otpHash          String
  expiresAt        DateTime
  passwordHash     String
  role             Role
  name             String?
  phone            String?
  companyName      String?
  gstin            String?
  pan              String?
  bankAccount      String?
  ifscCode         String?
  accountName      String?
  createdAt        DateTime @default(now())
}

model OtpVerification {
  email     String   @id
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model LotListing {
  id             String             @id @default(cuid())
  vendorId       String
  vendor         VendorProfile      @relation(fields: [vendorId], references: [id])
  title          String
  description    String?            @db.Text
  highlights     String[]           @default([])
  coverImage     String?
  totalQuantity  Int
  lotSize        Int
  totalLots      Int
  lotsSold       Int                @default(0)
  pricePerLot    Float
  status         LotStatus          @default(DRAFT)
  csvRawUrl      String?
  csvCleanUrl    String?
  /// Exact CSV text the vendor uploaded at listing creation (for download-original).
  uploadedCsvSnapshot String?        @db.Text
  verificationId String?
  /// Set when inspector has verified the lot listing (default true for trusted catalogue).
  inspectorVerified Boolean         @default(true)
  liveAt         DateTime?
  dispatchedAt   DateTime?
  items          LotInventoryItem[]
  purchases      LotPurchase[]
  lotBids        LotBid[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([vendorId])
  @@index([status])
}

model LotBid {
  id              String            @id @default(cuid())
  customerId      String
  customer        CustomerProfile   @relation(fields: [customerId], references: [id])
  lotId           String
  lot             LotListing        @relation(fields: [lotId], references: [id])
  lotsCount       Int
  bidPricePerLot  Float
  totalBidAmount  Float
  paymentOption   String            @default("FULL")
  note            String?           @db.Text
  status          BidStatus         @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([lotId])
}

model LotInventoryItem {
  id                  String            @id @default(cuid())
  lotId               String
  lot                 LotListing        @relation(fields: [lotId], references: [id], onDelete: Cascade)
  brand               String
  model               String
  generation          String?
  processor           String
  ramGb               Int
  storageGb           Int
  storageType         String
  displayInch         Float
  os                  String
  condition           LotItemCondition
  count               Int
  unitPrice           Float
  notes               String?
  cosmeticSummary     String?           @db.Text
  functionalCount     Int?
  nonFunctionalCount  Int?
  inspectorCondition  LotItemCondition?
  inspectorCount      Int?
  isVerified          Boolean           @default(false)
  inspectorItemNotes  String?           @db.Text

  @@index([lotId])
}

model LotPurchase {
  id              String          @id @default(cuid())
  reference       String?         @unique
  lotId           String
  lot             LotListing      @relation(fields: [lotId], references: [id])
  customerId      String
  customer        CustomerProfile @relation(fields: [customerId], references: [id])
  addressId       String?
  address         Address?        @relation(fields: [addressId], references: [id])
  lotsCount       Int
  totalUnits      Int
  amountPaid      Float           @default(0)
  paymentId       String?
  status          String          @default("PAID")
  paymentOption   String          @default("FULL")
  subtotal        Float?
  gstAmount       Float?
  grandTotal      Float?
  tokenAmount     Float?
  balanceDueAt    DateTime?
  balancePaidAt   DateTime?
  razorpayOrderId String?
  customerGstin   String?
  manifest        Json?
  dispatchCarrier String?
  dispatchAwb     String?
  dispatchedAt    DateTime?
  createdAt       DateTime        @default(now())

  @@index([lotId])
  @@index([customerId])
  @@index([razorpayOrderId])
}

model AsAsListing {
  id              String              @id @default(cuid())
  vendorId        String
  vendor          VendorProfile       @relation(fields: [vendorId], references: [id])
  title           String
  description     String?             @db.Text
  highlights      String[]            @default([])
  totalUnits      Int
  unitsSold       Int                 @default(0)
  avgUnitPrice    Float
  totalValue      Float
  allowBidding    Boolean             @default(true)
  allowMultiBuyer Boolean             @default(false)
  aiSuggestedLots Int?
  status          LotStatus           @default(DRAFT)
  csvRawUrl       String?
  csvCleanUrl     String?
  uploadedCsvSnapshot String?        @db.Text
  verificationId  String?
  /// Set when inspector has verified the AsAs listing (default true for trusted catalogue).
  inspectorVerified Boolean           @default(true)
  items           AsAsInventoryItem[]
  purchases       AsAsPurchase[]
  asAsBids        AsAsBid[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([vendorId])
  @@index([status])
}

model AsAsBid {
  id              String          @id @default(cuid())
  customerId      String
  customer        CustomerProfile @relation(fields: [customerId], references: [id])
  asasId          String
  asas            AsAsListing     @relation(fields: [asasId], references: [id])
  quantity        Int
  bidPricePerUnit Float
  totalBidAmount  Float
  paymentOption   String          @default("FULL")
  note            String?         @db.Text
  status          BidStatus       @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([customerId])
  @@index([asasId])
}

model AsAsInventoryItem {
  id                 String            @id @default(cuid())
  asasId             String
  asas               AsAsListing       @relation(fields: [asasId], references: [id], onDelete: Cascade)
  brand              String
  model              String
  generation         String?
  processor          String
  ramGb              Int
  storageGb          Int
  storageType        String
  condition          LotItemCondition
  count              Int
  estimatedValue     Float
  /// Operational / non-functional notes (e.g. inspection Status column) for exports.
  notes              String?           @db.Text
  cosmeticSummary    String?           @db.Text
  functionalCount    Int?
  nonFunctionalCount Int?
  displayInch        Float?
  inspectorCondition LotItemCondition?
  inspectorCount     Int?
  isVerified         Boolean           @default(false)
  inspectorItemNotes String?           @db.Text

  @@index([asasId])
}

model AsAsPurchase {
  id              String          @id @default(cuid())
  reference       String?         @unique
  asasId          String
  asas            AsAsListing     @relation(fields: [asasId], references: [id])
  customerId      String
  customer        CustomerProfile @relation(fields: [customerId], references: [id])
  addressId       String?
  address         Address?        @relation(fields: [addressId], references: [id])
  quantity        Int
  amountPaid      Float           @default(0)
  paymentId       String?
  status          String          @default("PAID")
  paymentOption   String          @default("FULL")
  subtotal        Float?
  gstAmount       Float?
  grandTotal      Float?
  tokenAmount     Float?
  balanceDueAt    DateTime?
  balancePaidAt   DateTime?
  razorpayOrderId String?
  customerGstin   String?
  manifest        Json?
  dispatchCarrier String?
  dispatchAwb     String?
  dispatchedAt    DateTime?
  createdAt       DateTime        @default(now())

  @@index([asasId])
  @@index([customerId])
  @@index([razorpayOrderId])
}

model Inspector {
  id        String             @id @default(cuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      InspectorType      @default(INHOUSE)
  name      String
  phone     String?
  cityZones String[]           @default([])
  isActive  Boolean            @default(true)
  tasks     VerificationTask[]

  @@index([isActive])
}

model VerificationTask {
  id              String             @id @default(cuid())
  listingType     ListingType
  listingId       String
  vendorId        String
  vendor          VendorProfile      @relation(fields: [vendorId], references: [id])
  inspectorId     String?
  inspector       Inspector?         @relation(fields: [inspectorId], references: [id])
  status          VerificationStatus @default(PENDING_ASSIGNMENT)
  proposedSlots   Json               @default("[]")
  confirmedSlot   Json?
  vendorAddress   String?            @db.Text
  inspectorNotes  String?            @db.Text
  report               Json?
  photos               String[]           @default([])
  rejectionReason      String?            @db.Text
  correctedTitle       String?            @db.Text
  correctedDescription String?            @db.Text
  correctedHighlights  String[]           @default([])
  originalItemsJson    Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([vendorId])
  @@index([listingType, listingId])
  @@index([status])
  @@index([inspectorId])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  label     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)
  orders        Order[]
  lotPurchases  LotPurchase[]
  asAsPurchases AsAsPurchase[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  icon     String?
  products Product[]
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String           @db.Text
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  brand       String
  specs       Json
  images      String[]
  isFeatured  Boolean          @default(false)
  /// Set by admin after on-site / inspector verification of inventory.
  inspectorVerified Boolean    @default(false)
  isActive    Boolean          @default(true)
  hsnCode     String           @default("8471")
  createdAt   DateTime         @default(now())
  listings    ProductListing[]
}

model ProductListing {
  id                    String            @id @default(cuid())
  productId             String
  product               Product           @relation(fields: [productId], references: [id])
  vendorId              String
  vendor                VendorProfile     @relation(fields: [vendorId], references: [id])
  sku                   String            @unique
  unitPrice             Float
  bulkPricing           Json?
  stockQty              Int               @default(0)
  minOrderQty           Int               @default(1)
  minBidPrice           Float
  isActive              Boolean           @default(true)
  condition             ProductCondition  @default(BRAND_NEW)
  conditionNotes        String?
  refurbImages          String[]          @default([])
  requiresAdminApproval Boolean           @default(false)
  bids                  Bid[]
  orderItems            OrderItem[]
}

model Bid {
  id                String          @id @default(cuid())
  customerId        String
  customer          CustomerProfile @relation(fields: [customerId], references: [id])
  listingId         String
  listing           ProductListing  @relation(fields: [listingId], references: [id])
  quantity          Int
  bidPricePerUnit   Float
  totalBidAmount    Float
  status            BidStatus       @default(PENDING)
  vendorNote        String?
  counterPrice      Float?
  expiresAt         DateTime?
  paymentOption     String          @default("FULL")
  revisionCount     Int             @default(0)
  revisionHistory   Json            @default("[]")
  order             Order?
  proformaInvoice   Invoice?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customerId  String
  customer    CustomerProfile @relation(fields: [customerId], references: [id])
  bidId       String?     @unique
  bid         Bid?        @relation(fields: [bidId], references: [id])
  addressId   String
  address     Address     @relation(fields: [addressId], references: [id])
  items       OrderItem[]
  subtotal    Float
  gstAmount   Float
  totalAmount Float
  status      OrderStatus @default(PAYMENT_PENDING)
  adminNotes  String?     @db.Text
  tokenAmount        Float?
  tokenPercentage    Float?
  tokenPaidAt        DateTime?
  balanceDueAt       DateTime?
  balancePaidAt      DateTime?
  tokenForfeitedAt   DateTime?
  isTokenForfeited   Boolean     @default(false)
  balanceReminder48hSent Boolean @default(false)
  balanceReminder24hSent Boolean @default(false)
  balanceReminder2hSent  Boolean @default(false)
  payments    Payment[]
  reviews     Review[]
  invoices    Invoice[]
  shipment    Shipment?
  payouts     Payout[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id])
  listingId String
  listing   ProductListing @relation(fields: [listingId], references: [id])
  quantity  Int
  unitPrice Float
  subtotal  Float
}

model Payment {
  id                String    @id @default(cuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id])
  razorpayOrderId   String
  razorpayPaymentId String?
  amount            Float
  currency          String    @default("INR")
  status            String    @default("pending")
  method            String?
  paidAt            DateTime?
  paymentPurpose    String    @default("FULL")

  @@index([orderId])
}

model Invoice {
  id                     String      @id @default(cuid())
  orderId                String?
  order                  Order?      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bidId                  String?     @unique
  bid                    Bid?        @relation(fields: [bidId], references: [id], onDelete: SetNull)
  referencesTaxInvoiceId String?
  invoiceNumber          String      @unique
  type                   InvoiceType @default(TAX)
  fileUrl                String?     @db.Text
  issuedAt               DateTime    @default(now())

  @@unique([orderId, type])
  @@index([orderId])
}

model Shipment {
  id           String    @id @default(cuid())
  orderId      String    @unique
  order        Order     @relation(fields: [orderId], references: [id])
  carrier      String
  awbNumber    String
  trackingUrl  String?
  status       String    @default("dispatched")
  dispatchedAt DateTime  @default(now())
  deliveredAt  DateTime?
  events       Json      @default("[]")
}

model Payout {
  id               String       @id @default(cuid())
  vendorId         String
  vendor           VendorProfile @relation(fields: [vendorId], references: [id])
  orderId          String
  order            Order        @relation(fields: [orderId], references: [id])
  grossAmount      Float
  commissionRate   Float
  commissionAmount Float
  netAmount        Float
  status           PayoutStatus @default(PENDING)
  utrNumber        String?
  releasedAt       DateTime?
  createdAt        DateTime     @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model SupportTicket {
  id         String   @id @default(cuid())
  raisedById String
  raisedBy   User     @relation(fields: [raisedById], references: [id])
  orderId    String?
  subject    String
  status     String   @default("open")
  messages   Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PlatformSettings {
  id                  String @id @default("singleton")
  companyName         String @default("Rentfoxxy Technology Pvt. Ltd.")
  companyPhone        String @default("")
  companyEmail        String @default("")
  gstin               String @default("")
  pan                 String @default("")
  address             String @default("")
  companyState        String @default("Karnataka")
  defaultCommission   Float  @default(8.0)
  razorpayKeyId       String @default("")
  razorpayKeySecret   String @default("")
  invoicePrefix       String @default("RFX-INV")
  proformaPrefix      String @default("RFX-PRO")
  creditNotePrefix    String @default("RFX-CN")
  orderPrefix         String @default("RFX-ORD")
  webhookPublicUrl    String @default("")
  invoiceCounterYear  Int    @default(0)
  invoiceCounterValue Int    @default(0)
  tokenForfeitVendorShare Float @default(30.0)
}

model Review {
  id           String     @id @default(cuid())
  type         ReviewType
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User       @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  subjectId    String
  rating       Int
  comment      String?    @db.Text
  tags         String[]   @default([])
  isPublic     Boolean    @default(true)
  isVerified   Boolean    @default(true)
  adminFlagged Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([orderId, reviewerId, type])
  @@index([subjectId, type])
}
