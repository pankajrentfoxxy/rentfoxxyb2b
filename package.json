{
  "name": "rentfoxxy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }) } catch (_) {}\"",
    "dev": "next dev",
    "dev:bind": "next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:push": "prisma db push",
    "db:sql:regen": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/init_from_empty.sql",
    "db:schema:apply": "node scripts/apply-sql.mjs",
    "db:local:up": "prisma dev --name rentfoxxy --detach",
    "db:setup": "node scripts/apply-sql.mjs && prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
