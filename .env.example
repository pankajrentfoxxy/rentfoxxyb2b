# Copy to .env.local and fill in values.

# Local PostgreSQL (DBeaver / Docker / installer).
# On Windows prefer 127.0.0.1 instead of localhost if connections drop (IPv6 vs IPv4).
# Local: set DIRECT_URL the same as DATABASE_URL unless you use a pooler locally.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/rentfoxxy?schema=public"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/rentfoxxy?schema=public"

# Optional: use JS pg adapter for PrismaClient in the app (default is off = Rust engine).
# PRISMA_USE_PG_ADAPTER="true"

# Resend (registration OTP, order & balance emails): https://resend.com
# If unset, FROM defaults to Rentfoxxy <onboarding@resend.dev> until you verify a domain.
RESEND_API_KEY=""
FROM_EMAIL=""
FROM_NAME="Rentfoxxy"

# Twilio SMS (optional; mocked when keys missing or non-production)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# WhatsApp Cloud API (optional; mocked when unset)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# Gemini — lot/AsAs CSV cleaning & naming (optional; heuristic fallback when unset)
GEMINI_API_KEY=""
# Default in code: gemini-2.0-flash-latest. Override if needed:
# GEMINI_MODEL="gemini-2.0-flash-latest"

# Required for Auth.js / NextAuth — do not commit the real value.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Optional: Auth.js also reads this if AUTH_SECRET is unset
# NEXTAUTH_SECRET=""

# --- Razorpay (test / demo checkout) ---
# Create an account at https://razorpay.com/ and use Test Mode keys from Settings → API Keys.
# Server: secret must stay server-only. The app creates a Razorpay Order and opens Checkout on the client.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Recommended: same Key ID for the browser (safe to expose). Falls back to RAZORPAY_KEY_ID if unset.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
#
# Without keys, payment APIs return 503. For local demos only (never production):
# PAYMENT_DEV_BYPASS=true
#
# Test payments: use Razorpay’s test cards / UPI IDs from their docs (Dashboard → Developers while in test mode).

# --- Supabase (optional; Auth.js still drives login — use for Supabase Auth / Realtime / Storage later) ---
# Project Settings → API. Publishable key may appear as "anon" / "publishable" (sb_publishable_... or JWT).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=""
# Optional: ms cap for Supabase session refresh in middleware (stops hangs if URL/key/network is bad)
# SUPABASE_MIDDLEWARE_TIMEOUT_MS="5000"
#
# Supabase + Prisma (Vercel): In Dashboard → Connect → ORM → Prisma, copy both URLs.
#   DATABASE_URL = Transaction pooler (port 6543), often with ?pgbouncer=true
#   DIRECT_URL   = Session mode or direct host (port 5432) — used by `prisma migrate`
# Do not commit passwords. Set these only in .env.local and Vercel Environment Variables.
