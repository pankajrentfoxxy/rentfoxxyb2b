# Copy to .env.local and fill in values.

# Local PostgreSQL (DBeaver / Docker / installer).
# On Windows prefer 127.0.0.1 instead of localhost if connections drop (IPv6 vs IPv4).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/rentfoxxy?schema=public"

# Optional: use JS pg adapter for PrismaClient in the app (default is off = Rust engine).
# PRISMA_USE_PG_ADAPTER="true"

# Required for Auth.js / NextAuth — do not commit the real value.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Optional: Auth.js also reads this if AUTH_SECRET is unset
# NEXTAUTH_SECRET=""

# --- Razorpay (test / demo checkout) ---
# Create an account at https://razorpay.com/ and use Test Mode keys from Settings → API Keys.
# Server: secret must stay server-only. The app creates a Razorpay Order and opens Checkout on the client.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Recommended: same Key ID for the browser (safe to expose). Falls back to RAZORPAY_KEY_ID if unset.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
#
# Without keys, payment APIs return 503. For local demos only (never production):
# PAYMENT_DEV_BYPASS=true
#
# Test payments: use Razorpay’s test cards / UPI IDs from their docs (Dashboard → Developers while in test mode).

# --- Supabase (optional; Auth.js still drives login — use for Supabase Auth / Realtime / Storage later) ---
# Project Settings → API. Publishable key may appear as "anon" / "publishable" (sb_publishable_... or JWT).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=""
#
# When moving Prisma from local Postgres to Supabase Postgres, set DATABASE_URL to the pooler or direct string
# from Supabase (Settings → Database). Use the *transaction* pooler URL for serverless if Prisma docs recommend it.
# Do not commit the database password; set it only in .env.local or your host’s secret store.
